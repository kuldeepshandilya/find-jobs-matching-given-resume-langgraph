# To separate your traces from other application
LANGSMITH_PROJECT=new-agent

#Model Name - Depending on your Open API account/api-key, you may need to change the model name if your Open API account or API Key does not have access to below model name
# To Know models supported for your Open AI API Key, use the command - curl https://api.openai.com/v1/models -H "Authorization: Bearer <YOUR_OPEN_AI_API_KEY>"
MODEL_NAME=gpt-3.5-turbo-0125

# Add API keys for connecting to LLM providers, data sources, and other integrations here
LANGSMITH_API_KEY=<Enter Your_LANGSMITH API KEY>>
OPENAI_API_KEY=<Enter Your OPEN API Key>

